# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Analytics
NEXT_PUBLIC_GA_ID=G-6RBFS2812S

# Admin panel (temporal hasta Supabase Auth)
# ADMIN_PASSWORD_HASH: bcrypt hash con factor 12 de la password plana.
# Generar con: node -e "console.log(require('bcryptjs').hashSync('TU_PASSWORD', 12))"
# Pegar el hash resultante en Vercel env vars (NO la password plana).
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Secreto para firmar cookies de sesión admin (HMAC-SHA256).
# SOLO server-side. Rotarlo invalida todas las sesiones vivas.
# Generar con: openssl rand -hex 32   (o: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ADMIN_SESSION_SECRET=

# Cron auth — SOLO server-side, NUNCA usar prefijo NEXT_PUBLIC_.
# Usado por /api/scrape (Vercel Cron). El dashboard admin NO lo usa.
CRON_SECRET=
